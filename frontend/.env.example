# ─────────────────────────────────────────────────────────────────────────────
# Diamond Agent — frontend environment
# Copy to .env.local for local dev. In production (Vercel) set these as
# Project → Settings → Environment Variables. All NEXT_PUBLIC_* are exposed to
# the browser (safe: the anon key is meant to be public; RLS + the backend
# enforce access).
# ─────────────────────────────────────────────────────────────────────────────

# Deployed backend URL. Local: http://localhost:3001
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Supabase project URL (Settings → API → Project URL).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (Settings → API → Project API keys → anon public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
