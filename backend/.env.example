# Absolute path to your GCP service account JSON key.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Your GCP project that has Vertex AI enabled.
GOOGLE_VERTEX_PROJECT=your-gcp-project-id

# Region for Vertex AI calls (publisher endpoint).
GOOGLE_VERTEX_LOCATION=us-central1

# Backend HTTP port.
PORT=3001

# Frontend origin for CORS.
FRONTEND_ORIGIN=http://localhost:3000

# Postgres (matches docker-compose.yml defaults).
DATABASE_URL=postgres://diamond:diamond@localhost:5432/diamond_agent

# Embedding model + vision model.
EMBED_MODEL=gemini-embedding-2
VISION_MODEL=gemini-2.5-flash

# Image generation model (Nano Banana). Runs on regional endpoints.
IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_LOCATION=us-central1

# Meshy AI — image-to-3D for the "3D Draft" step on top of a generated design.
# Get a key at https://www.meshy.ai/api. The real value lives in backend/.env (gitignored).
# REQUIRED: the server will refuse to start without this.
MESHY_API_KEY=msy_your_meshy_api_key_here
