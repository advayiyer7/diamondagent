# ─────────────────────────────────────────────────────────────────────────────
# Diamond Agent — backend environment
# Copy to .env for local dev. In production (Railway) set these as service vars.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Vertex AI (embeddings + vision + image generation) ────────────────
# LOCAL: absolute path to your downloaded service-account JSON key.
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# PRODUCTION (Railway can't mount files): instead of the path above, paste the
# ENTIRE contents of the JSON key into this one var and leave the path unset.
# The server writes it to a temp file on boot (see src/bootstrap-creds.ts).
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Your GCP project that has Vertex AI enabled.
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
# Region for Vertex AI calls (publisher endpoint).
GOOGLE_VERTEX_LOCATION=us-central1

# ── Supabase (auth + database) ───────────────────────────────────────────────
# Project URL, e.g. https://abcdefgh.supabase.co  (Settings → API → Project URL)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (Settings → API → Project API keys → service_role). SECRET —
# backend only, never ship to the browser. Used to validate user access tokens.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres connection string. Use the Supabase pooler ("Connection string" →
# "Transaction"/pooler, port 6543) for serverless-style hosts; the direct 5432
# string is fine for a single always-on backend.
DATABASE_URL=postgresql://postgres.your-project:PASSWORD@aws-region.pooler.supabase.com:5432/postgres

# ── Meshy AI — image-to-3D ───────────────────────────────────────────────────
# Get a key at https://www.meshy.ai/api. REQUIRED: server refuses to start without it.
MESHY_API_KEY=msy_your_meshy_api_key_here

# ── Server ───────────────────────────────────────────────────────────────────
# Backend HTTP port (Railway injects PORT automatically).
PORT=3001
# Exact origin of the deployed frontend, for CORS. Local: http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# ── Models (optional overrides) ──────────────────────────────────────────────
EMBED_MODEL=gemini-embedding-2
VISION_MODEL=gemini-2.5-flash
IMAGE_MODEL=gemini-2.5-flash-image
IMAGE_LOCATION=us-central1
